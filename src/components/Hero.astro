---
---
<section id="top">
  <div class="inner" data-reveal>
    <p class="eyebrow">Manuscript Editing &amp; Care</p>
    <h1>HK&nbsp;Editing</h1>
    <p class="tagline">Thoughtful editing for writers who care about their words.</p>
    <a href="#contact" class="cta">Work With Me</a>
  </div>
  <div class="flourish" data-reveal style="transition-delay: 0.15s">
    <span class="rule"></span>
    <span class="label">an independent editor</span>
    <span class="rule"></span>
  </div>
</section>

<style>
  section {
    max-width: 1120px;
    margin: 0 auto;
    padding: clamp(80px, 14vw, 150px) 32px clamp(70px, 11vw, 120px);
    text-align: center;
  }

  .eyebrow {
    font-family: var(--font-ui);
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 30px;
  }

  h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(48px, 9vw, 104px);
    line-height: 1.02;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin-bottom: 28px;
  }

  .tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(22px, 3.4vw, 32px);
    color: var(--muted);
    max-width: 620px;
    margin: 0 auto 42px;
    line-height: 1.35;
  }

  .cta {
    display: inline-block;
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--bg);
    background: var(--ink);
    padding: 17px 38px;
    border-radius: 2px;
    border: none;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .cta:hover {
    background: var(--accent);
    transform: translateY(-2px);
  }

  .flourish {
    margin-top: clamp(60px, 9vw, 96px);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
  }

  .rule {
    display: block;
    height: 1px;
    width: 64px;
    background: var(--sage);
  }

  .label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 20px;
    color: var(--muted);
  }
</style>
