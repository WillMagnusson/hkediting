---
import type { Lang } from '../i18n/translations';
import { translations } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang];
---
<header>
  <div class="inner">
    <a href={lang === 'sv' ? '/' : '/en/'} class="wordmark">
      HK Editing
      <span class="dot" aria-hidden="true"></span>
    </a>
    <nav>
      <a href="#services">{t.nav.services}</a>
      <a href="#about">{t.nav.about}</a>
      <a href="#voices">{t.nav.voices}</a>
      <a href="#contact" class="nav-cta">{t.nav.contact}</a>
      <a href={t.langSwitch.href} class="lang-switch">{t.langSwitch.label}</a>
    </nav>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: saturate(120%) blur(6px);
    -webkit-backdrop-filter: saturate(120%) blur(6px);
    background: rgba(247, 243, 238, 0.82);
    border-bottom: 1px solid rgba(155, 163, 145, 0.4);
  }

  .inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 18px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .wordmark {
    text-decoration: none;
    color: var(--ink);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 26px;
    letter-spacing: 0.01em;
    display: flex;
    align-items: baseline;
    gap: 9px;
  }

  .dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    position: relative;
    top: -2px;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 30px;
    flex-wrap: wrap;
    font-family: var(--font-ui);
    font-size: 12.5px;
    font-weight: 500;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  nav a {
    text-decoration: none;
    color: var(--muted);
    transition: color 0.2s ease;
  }

  nav a:hover {
    color: var(--ink);
  }

  .nav-cta {
    color: var(--ink) !important;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
  }

  .lang-switch {
    color: var(--muted) !important;
    border: 1px solid rgba(155, 163, 145, 0.5);
    border-radius: 2px;
    padding: 4px 10px;
    font-size: 11px;
    letter-spacing: 0.14em;
    transition: color 0.2s ease, border-color 0.2s ease !important;
  }

  .lang-switch:hover {
    color: var(--ink) !important;
    border-color: var(--accent);
  }
</style>
