---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import About from '../components/About.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact';
import Footer from '../components/Footer.astro';
---

<Base title="HK Editing" description="Thoughtful editing for writers who care about their words.">
  <Header />
  <main>
    <Hero />
    <Services />
    <About />
    <Testimonials />

    <!-- Contact section wraps the React form in Astro markup for layout/heading -->
    <section id="contact" class="contact-section">
      <div class="contact-heading" data-reveal>
        <p class="eyebrow">Get In Touch</p>
        <h2>Let's talk about your manuscript</h2>
        <p class="intro">
          Tell me a little about your project and where it is in its life. I read every note myself
          and reply within a few days.
        </p>
      </div>
      <div class="contact-form" data-reveal style="transition-delay: 0.1s">
        <Contact client:visible />
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .contact-section {
    max-width: 840px;
    margin: 0 auto;
    padding: clamp(70px, 10vw, 120px) 32px;
  }

  .contact-heading {
    text-align: center;
    margin-bottom: clamp(40px, 6vw, 60px);
  }

  .eyebrow {
    font-family: var(--font-ui);
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(36px, 6vw, 58px);
    line-height: 1.08;
    color: var(--ink);
    margin-bottom: 18px;
  }

  .intro {
    color: var(--muted);
    max-width: 520px;
    margin: 0 auto;
    font-size: 18px;
  }
</style>
