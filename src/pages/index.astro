---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import About from '../components/About.astro';
import Work from '../components/Work.astro';
import Contact from '../components/Contact';
import Footer from '../components/Footer.astro';
import { translations } from '../i18n/translations';

const lang = 'sv' as const;
const t = translations[lang];
---

<Base title="HK Editing" description={t.hero.tagline} lang={lang}>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <Services lang={lang} />
    <About lang={lang} />
    <Work lang={lang} />

    <section id="contact" class="contact-section">
      <div class="contact-heading" data-reveal>
        <p class="eyebrow">{t.contact.eyebrow}</p>
        <h2>{t.contact.h2}</h2>
        <p class="intro">{t.contact.intro}</p>
      </div>
      <div class="contact-form" data-reveal style="transition-delay: 0.1s">
        <Contact lang={lang} client:visible />
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</Base>

<style>
  .contact-section {
    max-width: 840px;
    margin: 0 auto;
    padding: clamp(70px, 10vw, 120px) 32px;
  }

  .contact-heading {
    text-align: center;
    margin-bottom: clamp(40px, 6vw, 60px);
  }

  .eyebrow {
    font-family: var(--font-ui);
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(36px, 6vw, 58px);
    line-height: 1.08;
    color: var(--ink);
    margin-bottom: 18px;
  }

  .intro {
    color: var(--muted);
    max-width: 520px;
    margin: 0 auto;
    font-size: 18px;
  }
</style>
